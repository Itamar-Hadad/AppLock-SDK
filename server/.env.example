# Copy to .env and fill in real values (server/.env is gitignored).

# Signs the Portal session JWT. Any long random string; change for real use.
JWT_SECRET=dev-secret-change-me

# Google OAuth client (Google Cloud Console > APIs & Services > Credentials).
# Authorized redirect URI there must match GOOGLE_CALLBACK_URL exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Gmail SMTP for password-reset emails (Google Account > Security > App passwords;
# requires 2-Step Verification to be enabled first). Not your normal Gmail password.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Where the React Portal runs — used to build links in emails, OAuth redirects, and CORS.
PORTAL_URL=http://localhost:5173

# Persistent MongoDB Atlas cluster connection string (Atlas > Database > Connect > Drivers).
# Use the Database Access user's credentials, not your Atlas account login.
MONGO_URI=

# Redis Cloud cache (10-minute TTL for GET /api/config/:appId), free tier at redis.io/try-free.
# Format: redis://default:<password>@<endpoint>
REDIS_URL=